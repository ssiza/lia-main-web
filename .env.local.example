# Resend API key — get a free one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives booking notifications
NOTIFICATION_EMAIL=support@liahomeservices.com

# The "from" address for outgoing emails.
# On Resend free tier use: onboarding@resend.dev
# With a verified domain use: bookings@liahomeservices.com
FROM_EMAIL=onboarding@resend.dev

# Your site URL (used for OG tags in production)
NEXT_PUBLIC_SITE_URL=https://www.liahomeservices.com

# Dev only: hostnames allowed to load /_next from (comma-separated, no protocol/port).
# Required when you open the site from a phone using your computer’s LAN IP, e.g.
# http://192.168.1.50:3000 — put 192.168.1.50 here. Matches `Network:` URL from `npm run dev`.
# NEXT_ALLOWED_DEV_ORIGINS=192.168.1.50,10.0.0.98
